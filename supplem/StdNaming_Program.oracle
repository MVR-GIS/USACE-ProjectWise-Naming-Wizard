CREATE TABLE StdNaming_Program
(
   ID NUMBER(10,0)  NOT NULL,
   ProgramName NVARCHAR2(255) NOT NULL
);
DROP SEQUENCE SWS_StdNaming_Program_ID;
CREATE SEQUENCE SWS_StdNaming_Program_ID INCREMENT BY 1 START WITH 1;
CREATE OR REPLACE TRIGGER SWT_StdNaming_Program_ID
BEFORE INSERT ON StdNaming_Program
REFERENCING NEW AS NEW OLD AS OLD
FOR EACH ROW
WHEN(NEW.ID IS NULL)
BEGIN
   SELECT SWS_StdNaming_Program_ID.NEXTVAL INTO :NEW.ID FROM DUAL;
END;
/